# Docker / Postgres
POSTGRES_USER=liratrack_user
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=liratrack_db

# SQLAlchemy
DATABASE_URL=postgresql://liratrack_user:change_me@localhost:5432/liratrack_db
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
UNOFFICIAL_LBP_RATE_API_URL=https://rate.onrender.com/api/v1/dollarRate
RATE_FETCH_TIMEOUT_SECONDS=10

# Auth
JWT_SECRET_KEY=change_me_to_a_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_AUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# Email / Contact
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true
EMAIL_FROM=your_email@gmail.com
ADMIN_CONTACT_EMAIL=your_email@gmail.com
